# devbox config -- copy to ~/.config/devbox.env and fill in YOUR values.
#
#   cp scripts/devbox.env.example ~/.config/devbox.env
#   $EDITOR ~/.config/devbox.env
#
# This file (the .example) ships placeholder values only. Your real
# ~/.config/devbox.env is NOT in the repo and must never be committed.
# Only the Mac needs this; the VM auto-discovers everything from Azure IMDS.

DEVBOX_RG="my-resource-group"                      # REQUIRED: Azure resource group
DEVBOX_VM="my-vm-name"                             # REQUIRED: VM name
DEVBOX_SUB=""                                      # optional: empty = az default subscription
DEVBOX_SSH="my-vm.region.cloudapp.azure.com"       # REQUIRED for code/ssh: SSH host alias (match ~/.ssh/config)
DEVBOX_REMOTE_HOME="/home/youruser"                # REQUIRED for code: remote home; opens $DEVBOX_REMOTE_HOME/src/<project>
DEVBOX_DEFAULT_PROJECT="mysettings"                # project `devbox code` opens with no arg
DEVBOX_MONTHLY_CREDIT=""                            # optional; e.g. 150 (VS Enterprise). Shows
                                                   # "remaining = credit - month-to-date spend"
                                                   # on startup. Spend covers the WHOLE
                                                   # subscription (all resources), not just devbox.
